# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Secret used to verify HMAC tokens from the mobile app.
# Generate with: openssl rand -hex 32
# Set to "DISABLED" only for local development (no token validation).
VOTE_HMAC_SECRET=

# Admin token for protected endpoints (add/delete candidates).
# Generate with: openssl rand -hex 24
ADMIN_TOKEN=

# SQLite database file path.
DATABASE_URL=sqlite://votes.db

# Address and port to listen on.
LISTEN_ADDR=0.0.0.0:3000

# Log level: error | warn | info | debug | trace
RUST_LOG=info
